    "custom_liquid_6EggRU": {
      "type": "custom-liquid",
      "custom_css": [
        ".alz-section {padding: 20px 0 !important;}"
      ],
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<div class=\"alz-section alz-silmtr alz-reveal is-visible\" style=\"padding: 60px 0; background-color: #ffffff; font-family: system-ui, -apple-system, sans-serif;\">\n  <div class=\"alz-container\" style=\"max-width: 1000px; margin: 0 auto; padding: 0 20px;\">\n\n    <header class=\"alz-silmtr__head\" style=\"text-align: center; margin-bottom: 40px;\">\n      <p class=\"alz-eyebrow\" style=\"text-transform: uppercase; letter-spacing: 2px; font-size: 13px; margin-bottom: 12px; color: #0d1b3e; font-weight: 600;\">Performance</p>\n      <h2 class=\"alz-silmtr__title\" style=\"font-size: 2.8rem; margin: 0 0 20px 0; font-weight: 500; color: #0d1b3e; letter-spacing: -1px;\">\n        Moteur DC : silence garanti.\n      </h2>\n      <p class=\"alz-lede\" style=\"font-size: 1.25rem; color: #555; max-width: 650px; margin: 0 auto; line-height: 1.5; letter-spacing: normal;\">\n        Ce modèle tourne à 28 dB en utilisation normale. Vous dormez tranquille, vous travaillez sans gêne.\n      </p>\n    </header>\n\n    <div class=\"alz-silmtr__chart\" style=\"display: flex; flex-direction: column; gap: 16px; max-width: 800px; margin: 0 auto;\">\n      \n      <div class=\"alz-silmtr__row\" style=\"display: flex; align-items: center; justify-content: space-between;\">\n        <div class=\"alz-silmtr__label\" style=\"width: 160px; font-weight: 500; color: #555; font-size: 16px; flex-shrink: 0; letter-spacing: normal;\">Chuchotement</div>\n        <div class=\"alz-silmtr__bar-wrap\" style=\"flex: 1; background-color: #eef2fb; border-radius: 20px; height: 42px; overflow: hidden;\">\n          <div class=\"alz-silmtr__bar\" style=\"background-color: #aab8d6; height: 100%; width: 40%; border-radius: 20px; display: flex; align-items: center; justify-content: flex-end; padding-right: 20px; box-sizing: border-box;\">\n            <span class=\"alz-silmtr__value\" style=\"color: #fff; font-weight: 600; font-size: 14px; letter-spacing: normal;\">20 dB</span>\n    