<style>
  .cart-drawer .drawer__header {
    background-color: var(--cart-drawer-header-background);
    display: flex;
    flex-direction: column;
    gap: 12px; /* Espace équilibré entre le titre et la bannière */
    padding-bottom: 15px; /* Optionnel : ajuste l'espace avant le badge bleu "LIVRAISON GRATUITE" */
  }

  /* Alignement horizontal du titre et de la croix */
  .drawer__header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  /* Conteneur de la bannière ajusté pour faire toute la largeur */
  .cart-image-banner-cart_image_banner_cixc89 {
    display: block;
    width: 100%;
    margin-top: 5px;
    margin-bottom: 0px;
    overflow: hidden;
    position: relative;
    z-index: 1;
    flex-shrink: 0 !important;
  }

  .cart-image-banner-cart_image_banner_cixc89 .banner-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* L'image prend désormais 100% de la largeur et ajuste sa hauteur proportionnellement */
  .cart-image-banner-cart_image_banner_cixc89 .banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover; /* Permet d'occuper tout l'espace disponible sans bandes noires/blanches */
  }
</style>

<div class="drawer__header">
  <div class="drawer__header-top">
    <h2 class="drawer__heading">
      {{ 'sections.cart.title' | t -}}
      <span class="gb-cart-total-item">{{ cart.item_count }}</span>
    </h2>
    <button
      class="drawer__close"
      type="button"
      onclick="this.closest('cart-drawer').close()"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      <span class="svg-wrapper">
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>

  <div class="cart-image-banner-cart_image_banner_cixc89">
    <div class="banner-wrapper">
      <img src="//baugmann.com/cdn/shop/files/Expedition_sous_24-48h_800_x_100_px_2.png?v=1781721316&amp;width=800" alt="Cart banner" class="banner-image" loading="lazy">
    </div>
  </div>
</div>